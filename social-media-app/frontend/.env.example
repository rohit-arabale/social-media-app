# ─────────────────────────────────────────────────────────
# .env.example — Frontend Environment Variables Template
#
# Rename this file to ".env" and make sure the values are correct.
# Note: You MUST restart the frontend server if you change this file.
# ─────────────────────────────────────────────────────────

# The URL of your backend API (Development default: http://localhost:5000/api)
REACT_APP_API_URL=https://social-media-app-w9jx.onrender.com/api

# The base URL for images served by the backend
REACT_APP_BASE_URL=https://social-media-app-w9jx.onrender.com
